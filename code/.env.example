# Required: Your LLM provider API key
SIFTER_LLM_API_KEY=sk-...

# LLM model for extraction (vision-capable required for PDFs/images)
# Examples: openai/gpt-4o, anthropic/claude-3-5-sonnet-20241022, google/gemini-1.5-pro
SIFTER_LLM_MODEL=openai/gpt-4o

# LLM model for pipeline generation (cheaper model is fine)
SIFTER_PIPELINE_MODEL=openai/gpt-4o-mini

# MongoDB connection (default works with docker-compose)
SIFTER_MONGODB_URI=mongodb://localhost:27017
SIFTER_MONGODB_DATABASE=sifter

# Server
SIFTER_HOST=0.0.0.0
SIFTER_PORT=8000

# Upload directory
SIFTER_UPLOAD_DIR=./uploads
SIFTER_MAX_FILE_SIZE_MB=50
